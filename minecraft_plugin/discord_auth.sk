on join:
    set {auth.%player's uuid%} to true
    apply slowness 255 to player for 1000000000 ticks
    apply blindness 255 to player for 1000000000 ticks
    apply invisibility 255 to player for 1000000000 ticks
    apply resistance 255 to player for 100000000 ticks
    apply jump boost 255 to player for 10000000 ticks
    set player's gamemode to adventure

    set {_name} to player's name
    set {_request} to prepare GET request on "%{server}%/players/logged?mc_username=%{_name}%"
    set {_request}'s headers to "secret: %{secret}%"
    execute {_request}
    set {_response} to last response of {_request}

    if status code of {_response} is 200:
        set {_body} to body of {_response}
        set {_json} to json from {_body}
        set {_value} to value "logged" of {_json}
        if {_value} is true:
            remove slowness from player
            remove blindness from player
            remove resistance from player
            remove jump boost from player
            remove invisibility from player
            set {auth.%player's uuid%} to false
            set player's gamemode to survival
            send "&6[&3AUTH&6] &fVotre identité a été confirmée. Bon jeu !" to player
            stop

        send "&8&m--------------------------------" to player
        send "&6&l AUTHENTIFICATION" to player
        send "&8&m--------------------------------" to player
        send "&eCliquez sur le bouton suivant pour vous connecter et confirmer votre identité :" to player
        send "" to player
        send formatted "<red>[<link:""%{server}%/auth?mc_username=%{_name}%"">Connexion</link>]</red>" to player
        send "" to player
        send "&fUne fois l'authentification terminée, vous pourrez jouer." to player
        send "&8&m--------------------------------" to player

        while {auth.%player's uuid%} is true:
            wait a second
            if {_count} is 60:
                remove slowness from player
                remove blindness from player
                remove resistance from player
                remove jump boost from player
                remove invisibility from player
                set {auth.%player's uuid%} to false
                set player's gamemode to survival
                kick player due to "&6[&3AUTH&6] &cTemps de connexion écoulé, &eveuillez vous reconnecter pour réessayer&7. &n&7En cas de problème&7, contactez &badmin&7."
                stop

            add 1 to {_count}

            execute {_request}
            set {_response} to last response of {_request}

            if status code of {_response} is 200:
                set {_body} to body of {_response}
                set {_json} to json from {_body}
                set {_value} to value "logged" of {_json}
                if {_value} is true:
                    set player's gamemode to survival
                    remove slowness from player
                    remove blindness from player
                    remove invisibility from  player
                    remove resistance from player
                    remove jump boost from player
                    set {auth.%player's uuid%} to false
                    send "&6[&3AUTH&6] &fVotre identité a été confirmée. Bon jeu !" to player
                    stop
                if {_value} is "failed":
                    remove slowness from player
                    remove blindness from player
                    remove invisibility from  player
                    remove resistance from player
                    remove jump boost from player
                    set {auth.%player's uuid%} to false
                    kick player due to "&6[&3AUTH&6] &cConnexion échoue, &eveuillez vous reconnecter pour réessayer&7. &n&7En cas de problème&7, contactez &bb10&7."
                    stop

on chat:
    if {auth.%player's uuid%} is true:
        cancel event
on command:
    if {auth.%player's uuid%} is true:
        cancel event
on quit:
    set {auth.%player's uuid%} to false
on drop:
    if {auth.%player's uuid%} is true:
        cancel event
on inventory click:
    if {auth.%player's uuid%} is true:
        cancel event
on player move:
    if {auth.%player's uuid%} is true:
        cancel event
on swap hand item:
    if {auth.%player's uuid%} is true:
        cancel event
on right click:
    if {auth.%player's uuid%} is true:
        cancel event
on left click:
    if {auth.%player's uuid%} is true:
        cancel event
