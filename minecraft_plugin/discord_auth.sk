command /loginInfo <offline player>:
    permission: *
    trigger:
        set {_mc-username} to arg-1

        set {_request} to prepare GET request on "%{server}%/players/show"
        set {_request}'s headers to "secret: %{secret}%"
        add "mc_username:%{_mc-username}%" to query params of {_request}

        execute {_request}
        set {_response} to last response of {_request}

        set {_body} to body of {_response}
        set {_json} to json from {_body}

        if status code of {_response} is 200:
            set {_ds-username} to value "ds_username" of {_json}
            set {_first} to value "first_connection" of {_json}
            set {_change} to value "last_change" of {_json}
            send "&6[&3AUTH&6] &fLogin info of Minecraft player %{_mc-username}%:" to sender
            send "&eDiscord username: &f%{_ds-username}%" to sender
            send "&eFirst connection: &f%{_first}%" to sender
            send "&eLast account change: &f%{_change}%" to sender
        else if status code of {_response} is 502:
            send "&6[&3AUTH&6] &fweb backend is unreachable" to sender 
        else:
            set {_message} to value "error" of {_json}
            send "&6[&3AUTH&6] &f%{_message}%" to sender

