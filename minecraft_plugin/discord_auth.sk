on load:
    clear {auth::*}
    clear {secret}
    clear {server}
    set {server} to "https://authserver.com"
    set {secret} to "secretkey"

command /createLogin <string> <string>:
    permission: *
    trigger:
        set {_mc-username} to arg-1
        set {_ds-username} to arg-2

        set {_request} to prepare POST request on "%{server}%/players/create"
        set {_request}'s headers to "secret: %{secret}%"
        add "mc_username:%{_mc-username}%" to query params of {_request}
        add "ds_username:%{_ds-username}%" to query params of {_request}

        execute {_request}
        set {_response} to last response of {_request}

        set {_body} to body of {_response}
        set {_json} to json from {_body}

        if status code of {_response} is 200:
            set {_message} to value "ok" of {_json}
            send "&6[&3AUTH&6] &f%{_message}%" to sender
        else if status code of {_response} is 502:
            send "&6[&3AUTH&6] &fweb backend is unreachable" to sender 
        else:
            set {_message} to value "error" of {_json}
            send "&6[&3AUTH&6] &f%{_message}%" to sender

